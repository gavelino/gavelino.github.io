@inproceedings{avelino2017code,
  abbr        = {OSS},
  bibtex_show = {true},
  title       = {Code Authorship: an Empirical Analysis of the Linux Kernel Evolution},
  author      = {Avelino, Guilherme and Valente, Marco Tulio and Hora, Andr{\'e}},
  booktitle   = oss,
  series      = {IFIP Advances in Information and Communication Technology},
  year        = {2017},
  abstract    = {Understanding code authorship is essential for software maintenance and evolution. In this paper, we empirically investigate the notion of code ownership and authorship in the Linux Kernel, one of the largest open source projects in the world. We analyze the evolution of authorship over time and study how changes in code ownership affect software quality and maintainability.},
  selected    = {true}
}

@inproceedings{avelino2019abandonment,
  abbr        = {MSR},
  bibtex_show = {true},
  title       = {On the Abandonment and Survival of Open Source Projects: An Empirical Investigation},
  author      = {Avelino, Guilherme and Valente, Marco Tulio and Hora, Andr{\'e} and Coelho, Jailton},
  booktitle   = msr,
  year        = {2019},
  abstract    = {Open source software projects are often abandoned, which can have significant consequences for their users and the broader software ecosystem. In this paper, we conduct an empirical study to characterize project abandonment on GitHub, identifying key factors that distinguish projects that survive from those that are abandoned.}
}

@article{avelino2019truck,
  abbr        = {EMSE},
  bibtex_show = {true},
  title       = {Is Your Project Losing Its Best Developers? An Approach Based on the Truck Factor},
  author      = {Avelino, Guilherme and Valente, Marco Tulio and Hora, Andr{\'e}},
  journal     = emse,
  volume      = {24},
  year        = {2019},
  abstract    = {The Truck Factor (TF) is a metric that quantifies the number of developers that a project would critically lose if they were suddenly gone. In this paper, we propose a novel approach to compute the TF of software projects based on code authorship analysis. We apply our approach to a large set of GitHub projects and investigate the characteristics of TF-critical developers.},
  selected    = {true}
}

@inproceedings{avelino2016novel,
  abbr        = {ICSME},
  bibtex_show = {true},
  title       = {A Novel Approach for Estimating Truck Factors},
  author      = {Avelino, Guilherme and Passos, Leonardo and Hora, Andr{\'e} and Valente, Marco Tulio},
  booktitle   = icsme,
  year        = {2016},
  abstract    = {We present a novel approach to estimate the Truck Factor of software projects by combining degree-of-authorship metrics derived from version control history. Our evaluation on real-world open source projects shows that the approach is more accurate than existing baselines and can scale to large repositories.}
}
